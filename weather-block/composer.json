{
    "name": "adamsilverstein/wp-weather-block",
    "description": "A WordPress block that displays current weather conditions for a specified location using OpenWeatherMap API.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "The WordPress Contributors"
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "wp-coding-standards/wpcs": "^2.3",
        "phpstan/phpstan": "^1.8",
        "dealerdirect/phpcodesniffer-composer-installer": "^0.7.2"
    },
    "scripts": {
        "test:php": "phpunit",
        "lint:php": "phpcs --standard=WordPress .",
        "analyze": "phpstan analyse --level=5 weather-block.php tests"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
